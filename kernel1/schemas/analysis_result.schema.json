{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kernel1AnalysisResult",
  "type": "object",
  "required": ["case_id", "status", "candidates", "report"],
  "properties": {
    "case_id": {"type": "string"},
    "status": {"enum": ["certain", "uncertain", "clarifying", "rejected"]},
    "type": {"type": ["string", "null"]},
    "alias": {"type": ["string", "null"]},
    "quadra": {"type": ["string", "null"]},
    "confidence": {"type": "number"},
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "score"],
        "properties": {
          "type": {"type": "string"},
          "score": {"type": "number"}
        }
      }
    },
    "model_a": {
      "type": "array",
      "items": {"type": "string"}
    },
    "evidence_chain": {"type": "array"},
    "conflicts": {"type": "array"},
    "insufficiency": {"type": "array"},
    "refinement": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "properties": {
            "stage": {"type": "string"},
            "axis": {"type": "string"},
            "axis_description": {"type": "string"},
            "competing_types": {"type": "array", "items": {"type": "string"}},
            "added_quotes": {"type": "integer"}
          }
        }
      ]
    },
    "synthesis_pass": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "properties": {
            "verdict_type": {"type": "string"},
            "narrative": {"type": "string"},
            "coherence_confidence": {"type": "number", "minimum": 0, "maximum": 1},
            "main_competitor": {"type": "string"},
            "why_not_competitor": {"type": "string"}
          }
        }
      ]
    },
    "arbitration": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "properties": {
            "voters": {"type": "object"},
            "decision": {"type": "string"},
            "reason": {"type": "string"}
          }
        }
      ]
    },
    "clarification_request": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["axis", "competing_types", "questions", "blocking_reason"],
          "properties": {
            "axis": {"type": "string"},
            "axis_description": {"type": "string"},
            "competing_types": {"type": "array", "items": {"type": "string"}, "maxItems": 2},
            "questions": {"type": "array", "items": {"type": "string"}, "minItems": 1, "maxItems": 3},
            "blocking_reason": {"type": "string"}
          }
        }
      ]
    },
    "report": {"type": "string"}
  }
}
